# 复制为 .env 后填入实际值；不要提交真实密钥
OPENAI_API_KEY=your_openai_api_key_here

# 可选，默认使用 OpenAI 官方地址；自托管或代理时填写，末尾不要加斜杠
OPENAI_API_BASE=https://api.openai.com/v1

# 可选，图片输出目录；不填则使用各脚本内置默认
# GPT_IMAGE_OUTPUT_DIR=./work_dir/generated_images_gpt_image_2

# 可选，review 默认模型；不填则最终回退到 gpt-4o
# GPT_IMAGE_REVIEW_MODEL=gpt-4o

# 可选，consistency 默认模型；不填则最终回退到 gpt-4o
# GPT_IMAGE_CONSISTENCY_MODEL=gpt-4o

# 可选，功能开关；支持 true/false/1/0/on/off，默认 true
# GPT_IMAGE_REVIEW_ENABLED=true
# GPT_IMAGE_CONSISTENCY_ENABLED=true
